# ===== 必填 =====

# TMDB API Key（Bearer Token 格式）—— 从 https://www.themoviedb.org/settings/api 获取
TMDB_API_KEY=

# OMDb API Key —— 从 https://www.omdbapi.com/apikey.aspx 获取（可选，作为 IMDb 评分的备用数据源）
OMDB_API_KEY=

# ===== 流媒体平台观看区域 =====
# 每个平台可设置逗号分隔的地区代码，留空使用默认值
# 默认区域：TW,HK,SG,MY（亚马逊和 Hulu 额外包含 JP）
# NETFLIX_WATCH_REGIONS=TW,HK,SG,MY
# DISNEY_WATCH_REGIONS=TW,HK,SG,MY
# MAX_WATCH_REGIONS=TW,HK,SG,MY
# AMAZON_WATCH_REGIONS=TW,HK,SG,MY,JP
# APPLE_WATCH_REGIONS=TW,HK,SG,MY
# HULU_WATCH_REGIONS=TW,HK,SG,MY,JP

# ===== 自动同步配置 =====

# 是否启用定时同步（默认 true）
# SYNC_ENABLED=true

# 每日同步时间（默认 06:00 Asia/Shanghai）
# SYNC_HOUR=6
# SYNC_MINUTE=0
# SYNC_TIMEZONE=Asia/Shanghai

# 同步抓取最近 N 天内容（默认 30）
# SYNC_DAYS_BACK=30

# 每类内容最多抓取页数（默认 5）
# SYNC_MAX_PAGES=5

# 时间窗口拆分天数，0 表示不拆分（默认 0）
# SYNC_WINDOW_DAYS=0

# 空库时是否自动全量 bootstrap（默认 true）
# SYNC_BOOTSTRAP_ON_EMPTY=true

# Bootstrap 抓取范围：最近 N 天（默认 1825 ≈ 5 年）
# SYNC_BOOTSTRAP_DAYS_BACK=1825

# Bootstrap 每类最多页数（默认 29）
# SYNC_BOOTSTRAP_MAX_PAGES=29

# ===== 评分过滤 =====

# IMDb 最低评分（默认 7.0）
# MIN_IMDB_RATING=7.0

# IMDb 最低投票数（默认 50）
# MIN_IMDB_VOTES=50

# OMDb 最低投票数（默认 100）
# OMDB_MIN_VOTES=100

# 并发补全评分数（默认 30）
# ENRICH_CONCURRENCY=30

# ===== 本地同步上传（local_sync.py 专用）=====

# SCP 上传目标，例：root@192.168.1.2:/app/data/tracker.db
# ROUTER_TARGET=
