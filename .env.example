# TMDB API Key (获取地址: https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# OMDB API Key (获取地址: https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=your_omdb_api_key_here

# 数据库路径
DATABASE_URL=data/tracker.db

# 可选：本地同步脚本上传目标，例如 root@192.168.1.2:/app/data/tracker.db
ROUTER_TARGET=

# 自动同步配置：网站进程每天按此时间抓取 TMDB
SYNC_ENABLED=true
SYNC_HOUR=6
SYNC_MINUTE=0
SYNC_TIMEZONE=Asia/Shanghai
SYNC_DAYS_BACK=30
SYNC_MAX_PAGES=5
