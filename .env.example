# ===== 必填 =====

# TMDB API Key（Bearer Token 格式）—— 从 https://www.themoviedb.org/settings/api 获取
TMDB_API_KEY=

# OMDb API Key —— 从 https://www.omdbapi.com/apikey.aspx 获取（可选，作为 IMDb 评分的备用数据源）
OMDB_API_KEY=

# 数据库存储目录；软路由建议使用 USB 盘绝对路径
# TRACKER_DATA_DIR=/mnt/usb1_2-1/data

# ===== 流媒体平台观看区域 =====
# 每个平台可设置逗号分隔的地区代码，留空使用默认值
# 默认区域：TW,HK,SG,MY,JP,KR,US,GB,CA,AU
# NETFLIX_WATCH_REGIONS=TW,HK,SG,MY,JP,KR,US,GB,CA,AU
# DISNEY_WATCH_REGIONS=TW,HK,SG,MY,JP,KR,US,GB,CA,AU
# MAX_WATCH_REGIONS=TW,HK,SG,MY,JP,KR,US,GB,CA,AU
# AMAZON_WATCH_REGIONS=TW,HK,SG,MY,JP,KR,US,GB,CA,AU
# APPLE_WATCH_REGIONS=TW,HK,SG,MY,JP,KR,US,GB,CA,AU
# HULU_WATCH_REGIONS=TW,HK,SG,MY,JP,KR,US,GB,CA,AU

# 检查订阅、广告、免费、租赁及购买渠道
# WATCH_MONETIZATION_TYPES=flatrate,ads,free,rent,buy

# 外部请求重试次数（含 408/429/5xx 和 Retry-After）
# HTTP_RETRIES=3

# 已有作品详情缓存刷新周期（天）
# DETAIL_REFRESH_DAYS=7

# 暂无评分/请求失败作品的重试间隔（天）
# PENDING_RETRY_DAYS=1,3,7,14,30

# 连续未发现多少天后停用供应商链接
# PROVIDER_STALE_DAYS=45

# ===== 自动同步配置 =====

# 是否启用定时同步（默认 true）
# SYNC_ENABLED=true

# 每日同步时间（默认 06:00 Asia/Shanghai）
# SYNC_HOUR=6
# SYNC_MINUTE=0
# SYNC_TIMEZONE=Asia/Shanghai

# 同步抓取最近 N 天内容（默认 30）
# SYNC_DAYS_BACK=30

# 每类内容最多抓取页数（默认 5）
# SYNC_MAX_PAGES=5

# 时间窗口拆分天数，0 表示不拆分（默认 0）
# SYNC_WINDOW_DAYS=0

# 定时增量同步额外重叠天数，防止边界漏抓（默认 3）
# SYNC_INCREMENTAL_OVERLAP_DAYS=3

# 是否每次轮询一段历史目录，补偿迟到的上架元数据（默认 true）
# SYNC_CATALOG_SCAN_ENABLED=true

# 历史目录最远回看天数（默认 3650，约 10 年）
# SYNC_CATALOG_SCAN_DAYS_BACK=3650

# 每次历史补偿扫描的窗口大小（默认 365 天）
# SYNC_CATALOG_WINDOW_DAYS=365

# 空库时是否自动全量 bootstrap（默认 true）
# SYNC_BOOTSTRAP_ON_EMPTY=true

# Bootstrap 抓取范围：最近 N 天（默认 1825 ≈ 5 年）
# SYNC_BOOTSTRAP_DAYS_BACK=1825

# Bootstrap 每类最多页数（默认 29）
# SYNC_BOOTSTRAP_MAX_PAGES=29

# ===== 评分过滤 =====

# IMDb 最低评分（默认 7.0）
# MIN_IMDB_RATING=7.0

# IMDb 最低投票数（默认 50）
# MIN_IMDB_VOTES=50

# OMDb 最低投票数（默认 100）
# OMDB_MIN_VOTES=100

# 并发补全评分数（默认 30）
# ENRICH_CONCURRENCY=30

# 每批补全作品数（默认 200，至少为 1）
# ENRICH_BATCH_SIZE=200

# ===== 本地同步上传（local_sync.py 专用）=====

# SCP 上传目标，例：root@192.168.1.2:/app/data/tracker.db
# ROUTER_TARGET=
