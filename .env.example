# TMDB API Key (获取地址: https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# OMDB API Key (获取地址: https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=your_omdb_api_key_here

# 数据库路径
DATABASE_URL=data/tracker.db

# 可选：按平台覆盖 TMDB 观看地区，逗号分隔；不配置时使用中文区优先策略
# 默认：Netflix/Disney+/Max/Apple TV+ = TW,HK,SG,MY；Prime Video/Hulu = TW,HK,SG,MY,JP
# NETFLIX_WATCH_REGIONS=TW,HK,SG,MY
# DISNEY_WATCH_REGIONS=TW,HK,SG,MY
# MAX_WATCH_REGIONS=TW,HK,SG,MY
# AMAZON_WATCH_REGIONS=TW,HK,SG,MY,JP
# APPLE_WATCH_REGIONS=TW,HK,SG,MY
# HULU_WATCH_REGIONS=TW,HK,SG,MY,JP

# 可选：本地同步脚本上传目标，例如 root@192.168.1.2:/app/data/tracker.db
ROUTER_TARGET=

# 自动同步配置：网站进程每天按此时间抓取 TMDB
SYNC_ENABLED=true
SYNC_HOUR=6
SYNC_MINUTE=0
SYNC_TIMEZONE=Asia/Shanghai
SYNC_DAYS_BACK=30
SYNC_MAX_PAGES=5
# 0 表示按旧版逻辑使用一个连续时间范围；>0 才按天数分窗深扫
SYNC_WINDOW_DAYS=0
SYNC_BOOTSTRAP_ON_EMPTY=true
SYNC_BOOTSTRAP_DAYS_BACK=1825
SYNC_BOOTSTRAP_MAX_PAGES=29
